{
  "name": "assjm-hub",
  "version": "0.1.0",
  "private": true,
  "description": "ASSJM HUB — la plateforme qui fait vivre l'AS Saint-Just-Malmont",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:netlify": "node scripts/use-postgres.mjs && prisma generate && prisma db push && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset && prisma db seed",
    "postinstall": "prisma generate",
    "db:clean": "tsx prisma/seed-clean.ts",
    "og": "node scripts/make-og.mjs",
    "icons": "node scripts/make-icons.mjs",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "3.10.0",
    "@netlify/blobs": "^10.7.9",
    "@prisma/client": "6.3.1",
    "@radix-ui/react-slot": "1.1.1",
    "bcryptjs": "2.4.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "framer-motion": "11.18.2",
    "gsap": "3.12.7",
    "lucide-react": "0.474.0",
    "next": "15.1.11",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "0.4.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.54.2",
    "recharts": "2.15.0",
    "tailwind-merge": "2.6.0",
    "three": "0.169.0",
    "web-push": "^3.6.7",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.10.7",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/three": "0.169.0",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "15.1.6",
    "postcss": "8.5.1",
    "prisma": "6.3.1",
    "sharp": "^0.35.0",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "1.0.7",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "^4.1.9"
  }
}
