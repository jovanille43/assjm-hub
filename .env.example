# ─────────────── ASSJM HUB — variables d'environnement ───────────────
# Copier en `.env` et adapter.

# Base de données.
# Dev (par défaut) : SQLite, zéro config.
DATABASE_URL="file:./dev.db"
# Production (recommandé) : PostgreSQL — voir DEPLOYMENT.md.
# DATABASE_URL="postgresql://user:password@host:5432/assjm?schema=public"

# Auth.js v5 — génère un vrai secret en prod : `npx auth secret`
AUTH_SECRET="change-me-in-production"
AUTH_TRUST_HOST="true"

# URL publique du site (SEO, Open Graph, sitemap).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Push notifications (optionnel) — `npx web-push generate-vapid-keys`
# Sans ces clés, les notifications restent in-app uniquement.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
